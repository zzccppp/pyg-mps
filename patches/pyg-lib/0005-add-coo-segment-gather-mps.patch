+// Native MPS support for the COO segment/gather family.
+//
+// A COO segment reduction is exactly a scatter along `dim = index.dim() - 1`:
+// element `src[..., k, ...]` contributes to `out[..., index[..., k], ...]`.
+// So the whole `segment_*_coo` family delegates to the existing native/Metal
+// `scatter_*` kernels (sum/mul/mean native, min/max via the fused Metal kernel).
+// `gather_coo` is the inverse broadcast, i.e. a plain `index_select`.
+//
+// This turns a previously-unsupported hot aggregation path into native MPS with
+// no new kernel code, reusing the proven and benchmarked scatter implementations.
+
+#include "../scatter.h"
+#include "../segment_coo.h"
+#include "../segment_csr.h"
+#include "../utils.h"
+
+#include <ATen/ATen.h>
+#include <torch/library.h>
+
+#include <tuple>
+
+namespace pyg {
+namespace ops {
+namespace {
+
+int64_t reduce_dim(const at::Tensor& index) {
+  TORCH_CHECK(index.dim() >= 1, "segment_coo: index must have >= 1 dimension");
+  return index.dim() - 1;
+}
+
+// The scatter kernels expect an index already broadcast to `src.shape`. When we
+// call them from this backend, scatter's autograd broadcast layer is bypassed,
+// so we replicate it here with the same helper autograd uses.
+at::Tensor bcast(const at::Tensor& index, const at::Tensor& src, int64_t dim) {
+  return broadcast(index, src, dim);
+}
+
+at::Tensor segment_sum_coo_mps(const at::Tensor& src,
+                               const at::Tensor& index,
+                               const std::optional<at::Tensor>& out,
+                               std::optional<int64_t> dim_size) {
+  const int64_t dim = reduce_dim(index);
+  return scatter_sum(src, bcast(index, src, dim), dim, out, dim_size);
+}
+
+at::Tensor segment_mean_coo_mps(const at::Tensor& src,
+                                const at::Tensor& index,
+                                const std::optional<at::Tensor>& out,
+                                std::optional<int64_t> dim_size) {
+  const int64_t dim = reduce_dim(index);
+  return scatter_mean(src, bcast(index, src, dim), dim, out, dim_size);
+}
+
+std::tuple<at::Tensor, at::Tensor> segment_min_coo_mps(
+    const at::Tensor& src,
+    const at::Tensor& index,
+    const std::optional<at::Tensor>& out,
+    std::optional<int64_t> dim_size) {
+  const int64_t dim = reduce_dim(index);
+  return scatter_min(src, bcast(index, src, dim), dim, out, dim_size);
+}
+
+std::tuple<at::Tensor, at::Tensor> segment_max_coo_mps(
+    const at::Tensor& src,
+    const at::Tensor& index,
+    const std::optional<at::Tensor>& out,
+    std::optional<int64_t> dim_size) {
+  const int64_t dim = reduce_dim(index);
+  return scatter_max(src, bcast(index, src, dim), dim, out, dim_size);
+}
+
+// out[..., k, ...] = src[..., index[..., k], ...]; the broadcast inverse of a
+// segment reduction. For a 1-D index this is a plain index_select along `dim`.
+at::Tensor gather_coo_mps(const at::Tensor& src,
+                          const at::Tensor& index,
+                          const std::optional<at::Tensor>& out) {
+  const int64_t dim = reduce_dim(index);
+  TORCH_CHECK(index.dim() == 1,
+              "gather_coo (MPS): only a 1-D index is supported natively");
+  auto result = src.index_select(dim, index.contiguous());
+  if (out.has_value()) {
+    out.value().copy_(result);
+    return out.value();
+  }
+  return result;
+}
+
+// out[e, ...] = src[row(e), ...], where row(e) is the CSR row that contains
+// position e. Building the per-position row index (repeat_interleave of the
+// segment lengths) reduces this to a native index_select. Falls back to CPU for
+// a multi-dim indptr.
+at::Tensor gather_csr_mps(const at::Tensor& src,
+                          const at::Tensor& indptr,
+                          const std::optional<at::Tensor>& out) {
+  if (indptr.dim() != 1) {
+    auto res = gather_csr(src.cpu(), indptr.cpu(),
+                          out.has_value()
+                              ? std::optional<at::Tensor>(out->cpu())
+                              : std::nullopt)
+                   .to(src.device());
+    return res;
+  }
+  const int64_t N = indptr.size(0) - 1;
+  auto ip = indptr.contiguous();
+  auto counts = ip.slice(0, 1, N + 1) - ip.slice(0, 0, N);       // [N]
+  auto row = at::arange(N, ip.options()).repeat_interleave(counts);  // [E]
+  auto result = src.index_select(0, row);
+  if (out.has_value()) {
+    out.value().copy_(result);
+    return out.value();
+  }
+  return result;
+}
+
+}  // namespace
+
+TORCH_LIBRARY_IMPL(pyg, MPS, m) {
+  m.impl(TORCH_SELECTIVE_NAME("pyg::segment_sum_coo"),
+         TORCH_FN(segment_sum_coo_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::segment_mean_coo"),
+         TORCH_FN(segment_mean_coo_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::segment_min_coo"),
+         TORCH_FN(segment_min_coo_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::segment_max_coo"),
+         TORCH_FN(segment_max_coo_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::gather_coo"), TORCH_FN(gather_coo_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::gather_csr"), TORCH_FN(gather_csr_mps));
+}
+
+}  // namespace ops
+}  // namespace pyg
