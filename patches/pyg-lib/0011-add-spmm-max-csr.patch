+// `[N_dst, F]` (int64). `arg` is non-differentiable.
+PYG_API std::tuple<at::Tensor, at::Tensor> spmm_max_csr(
+    const at::Tensor& x,
+    const at::Tensor& indptr,
+    const at::Tensor& col,
+    const std::optional<at::Tensor>& weight);
