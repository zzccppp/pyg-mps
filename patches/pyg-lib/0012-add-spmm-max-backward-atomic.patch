   m.impl(TORCH_SELECTIVE_NAME("pyg::spmm_csr"), TORCH_FN(spmm_csr_mps));
   m.impl(TORCH_SELECTIVE_NAME("pyg::spmm_max_csr"), TORCH_FN(spmm_max_csr_mps));
+  m.impl(TORCH_SELECTIVE_NAME("pyg::spmm_max_csr_bw"),
